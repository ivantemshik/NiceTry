# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# AppRoute API (поставщик gift-карт и пополнений)
# TODO: вставить реальный ключ X-API-Key, выданный поставщиком
APPROUTE_API_KEY=
# TODO: вставить реальный Base URL AppRoute ({BASE_URL} из PDF — выдаётся вместе с ключом)
APPROUTE_BASE_URL=

# Dessly API (поставщик отправки игр/гифтов в Steam)
# БОЕВАЯ АВТОРИЗАЦИЯ — ПОДПИСАННЫЙ запрос (спека dessly-openapi.json, проверено вживую, WORKLOG DSL-5):
#   X-Api-Key + X-Timestamp + X-Signature, где
#   X-Signature = HMAC-SHA256(secret, apiKey + timestamp + body) → lowercase hex (пустое тело = "").
# Боевой режим включается, ТОЛЬКО когда заданы И ключ, И секрет (иначе — мок-каталог).
DESSLY_API_KEY=
# Секрет подписи запросов (X-Signature), ОТДЕЛЬНЫЙ от ключа. Выдаётся в кабинете мерчанта Dessly.
# В запрос НЕ передаётся — только для расчёта подписи.
DESSLY_API_SECRET=
# Base URL Dessly. По умолчанию https://desslyhub.com (реальный, сверено по доке).
# Переопределять обычно НЕ нужно — оставьте пустым.
DESSLY_BASE_URL=
# Опционально: URL готового встраиваемого окна/виджета Dessly (send-gift). Если задан валидный
# http(s) URL — карточка «Отправь игру в стим» открывает ЕГО (embed), иначе — нативный экран.
# TODO: вставить, если Dessly подтвердит наличие hosted-окна/виджета (см. WORKLOG, Блок B1/B2)
DESSLY_WIDGET_URL=
# Опционально: комиссия сервиса (%) на экране отправки игры (на скрине 4%). По умолчанию 4.
# В Блоке B4 редактируется из админки; здесь — env-override.
DESSLY_SERVICE_COMMISSION_PERCENT=

# proxy6 / px6 (покупка прокси) — БОЕВАЯ интеграция (см. README, раздел «Прокси px6»).
# Ключ из личного кабинета px6 (раздел API). Без ключа клиент работает в мок-режиме
# (та же форма ответов), боевые запросы по покупателям не идут. НЕ хардкодить.
# TODO: вставить реальный PROXY6_API_KEY при старте интеграции прокси
PROXY6_API_KEY=
# База API px6. По умолчанию https://px6.link/api — переопределять обычно не нужно.
PROXY6_API_BASE=https://px6.link/api

# Pay4game (платёжная система - после верификации)
PAY4GAME_MERCHANT_ID=
PAY4GAME_SECRET_KEY=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Telegram Bot + Mini App (Этап 6)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_BOT_USERNAME=your_bot_username
# URL, открываемый в Mini App (витрина). На проде — домен Vercel.
TELEGRAM_WEBAPP_URL=https://your-domain.vercel.app/
# Секрет webhook (заголовок X-Telegram-Bot-Api-Secret-Token).
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret
# Часы задержки перед запросом отзыва (ТЗ §5.8).
TELEGRAM_REVIEW_DELAY_HOURS=24
# Секрет cron-эндпоинтов (Vercel Cron).
CRON_SECRET=your_cron_secret
